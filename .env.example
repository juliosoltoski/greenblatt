APP_HOST=localhost
PROXY_PORT=8080
BACKEND_IMAGE=greenblatt-backend:latest
FRONTEND_IMAGE=greenblatt-frontend:latest

DJANGO_SECRET_KEY=changeme-in-real-environments
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,backend,proxy
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:8080
DJANGO_ADMINS=
DJANGO_CACHE_BACKEND=locmem
DJANGO_CACHE_LOCATION=greenblatt-local-cache
DJANGO_SESSION_COOKIE_SAMESITE=Lax
DJANGO_CSRF_COOKIE_SAMESITE=Lax
DJANGO_SESSION_COOKIE_SECURE=false
DJANGO_CSRF_COOKIE_SECURE=false
DJANGO_SESSION_COOKIE_HTTPONLY=true
DJANGO_CSRF_COOKIE_HTTPONLY=false
DJANGO_SECURE_SSL_REDIRECT=false
DJANGO_SECURE_HSTS_SECONDS=0
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=false
DJANGO_SECURE_HSTS_PRELOAD=false
DJANGO_USE_X_FORWARDED_HOST=true
DJANGO_SECURE_REFERRER_POLICY=same-origin
DJANGO_SECURE_COOP=same-origin
DJANGO_X_FRAME_OPTIONS=DENY
DATABASE_CONN_MAX_AGE=60
ARTIFACT_STORAGE_BACKEND=filesystem
ARTIFACT_STORAGE_ROOT=/var/lib/greenblatt/artifacts
ARTIFACT_ORPHAN_RETENTION_HOURS=24
WORKSPACE_MAX_CONCURRENT_JOBS=8
WORKSPACE_MAX_CONCURRENT_RESEARCH_JOBS=2
WORKSPACE_MAX_CONCURRENT_SMOKE_JOBS=3
MARKET_DATA_PROVIDER=yahoo
MARKET_DATA_PROVIDER_FALLBACK=
ALPHA_VANTAGE_API_KEY=
ALPHA_VANTAGE_BASE_URL=https://www.alphavantage.co/query
ALPHA_VANTAGE_MAX_CALLS_PER_MINUTE=5
DRF_THROTTLE_BURST=240/min
DRF_THROTTLE_ANON=120/min
DRF_THROTTLE_LOGIN=20/min
DRF_THROTTLE_LAUNCH=60/hour
DRF_THROTTLE_EXPORT=120/hour
METRICS_AUTH_TOKEN=

POSTGRES_DB=greenblatt
POSTGRES_USER=greenblatt
POSTGRES_PASSWORD=greenblatt
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

REDIS_HOST=redis
# Host-exposed Redis port for local access; container-internal Redis stays on 6379.
REDIS_HOST_PORT=6380
REDIS_URL=redis://redis:6379/0

CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
CELERY_TASK_ALWAYS_EAGER=false
CELERY_TASK_EAGER_PROPAGATES=false
CELERY_TASK_SOFT_TIME_LIMIT=1500
CELERY_TASK_TIME_LIMIT=1800

EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=localhost
EMAIL_PORT=25
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=false
EMAIL_USE_SSL=false
DEFAULT_FROM_EMAIL=greenblatt@example.test
SERVER_EMAIL=greenblatt@example.test

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_BUCKET=greenblatt-artifacts
MINIO_ENDPOINT=http://minio:9000

LOG_LEVEL=INFO
LOG_JSON=false
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_RELEASE=
SENTRY_TRACES_SAMPLE_RATE=0
SENTRY_PROFILES_SAMPLE_RATE=0
SENTRY_SEND_DEFAULT_PII=false

NEXT_PUBLIC_APP_NAME=Greenblatt Web App
NEXT_PUBLIC_API_BASE_PATH=/api
