APP_HOST=localhost
PROXY_PORT=8080

DJANGO_SECRET_KEY=changeme-in-real-environments
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,backend,proxy
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:8080

POSTGRES_DB=greenblatt
POSTGRES_USER=greenblatt
POSTGRES_PASSWORD=greenblatt
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

REDIS_HOST=redis
# Host-exposed Redis port for local access; container-internal Redis stays on 6379.
REDIS_HOST_PORT=6380
REDIS_URL=redis://redis:6379/0

CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_BUCKET=greenblatt-artifacts
MINIO_ENDPOINT=http://minio:9000

NEXT_PUBLIC_APP_NAME=Greenblatt Web App
NEXT_PUBLIC_API_BASE_PATH=/api
