APP_HOST=staging.example.com
PROXY_PORT=80
APP_BASE_URL=https://staging.example.com
BACKEND_IMAGE=ghcr.io/example/greenblatt-backend:staging
FRONTEND_IMAGE=ghcr.io/example/greenblatt-frontend:staging

DJANGO_SECRET_KEY=replace-with-a-long-random-secret
DJANGO_DEBUG=false
DJANGO_ALLOWED_HOSTS=staging.example.com,localhost,127.0.0.1
DJANGO_CSRF_TRUSTED_ORIGINS=https://staging.example.com
DJANGO_ADMINS=ops@example.com
DJANGO_CACHE_BACKEND=redis
DJANGO_CACHE_LOCATION=redis://redis:6379/2
DJANGO_SESSION_COOKIE_SECURE=true
DJANGO_CSRF_COOKIE_SECURE=true
DJANGO_SECURE_SSL_REDIRECT=true
DJANGO_SECURE_HSTS_SECONDS=31536000
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=true
DJANGO_SECURE_HSTS_PRELOAD=true
DATABASE_CONN_MAX_AGE=300
WORKSPACE_MAX_CONCURRENT_JOBS=8
WORKSPACE_MAX_CONCURRENT_RESEARCH_JOBS=2
WORKSPACE_MAX_CONCURRENT_SMOKE_JOBS=2
MARKET_DATA_PROVIDER=yahoo
MARKET_DATA_PROVIDER_FALLBACK=
ALPHA_VANTAGE_API_KEY=
ALPHA_VANTAGE_BASE_URL=https://www.alphavantage.co/query
ALPHA_VANTAGE_MAX_CALLS_PER_MINUTE=5
DRF_THROTTLE_BURST=240/min
DRF_THROTTLE_ANON=120/min
DRF_THROTTLE_LOGIN=20/min
DRF_THROTTLE_LAUNCH=60/hour
DRF_THROTTLE_EXPORT=120/hour
METRICS_AUTH_TOKEN=replace-with-a-random-token

POSTGRES_DB=greenblatt
POSTGRES_USER=greenblatt
POSTGRES_PASSWORD=replace-with-a-db-password
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_HOST_USER=smtp-user
EMAIL_HOST_PASSWORD=replace-with-an-smtp-password
EMAIL_USE_TLS=true
EMAIL_USE_SSL=false
DEFAULT_FROM_EMAIL=greenblatt@example.com
SERVER_EMAIL=greenblatt@example.com

ARTIFACT_STORAGE_BACKEND=filesystem
ARTIFACT_STORAGE_ROOT=/var/lib/greenblatt/artifacts
ARTIFACT_ORPHAN_RETENTION_HOURS=24
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=replace-with-a-minio-password
MINIO_BUCKET=greenblatt-artifacts
MINIO_ENDPOINT=http://minio:9000

LOG_LEVEL=INFO
LOG_JSON=true
SENTRY_DSN=
SENTRY_ENVIRONMENT=staging
SENTRY_RELEASE=
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0
SENTRY_SEND_DEFAULT_PII=false

NEXT_PUBLIC_APP_NAME=Greenblatt Web App
NEXT_PUBLIC_API_BASE_PATH=/api
SMOKE_USERNAME=staging-smoke
SMOKE_PASSWORD=replace-with-a-smoke-password
